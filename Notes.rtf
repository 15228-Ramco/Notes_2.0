\par \hich\af31506\dbch\af31505\loch\f31506 Employees who joined in the last 30 days.
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT *
\par \hich\af31506\dbch\af31505\loch\f31506 FROM Employees
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE JoinDate >= DATEADD(DAY, -30, GETDATE());
\par 
\par 
\par ------------------------------------
\par \hich\af31506\dbch\af31505\loch\f31506 Count employees who joined each month.
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT YEAR(JoinDate) AS [Year],
\par \hich\af31506\dbch\af31505\loch\f31506        MONTH(JoinDate) AS [Month],
\par \hich\af31506\dbch\af31505\loch\f31506        COUNT(*) AS TotalEmployees
\par \hich\af31506\dbch\af31505\loch\f31506 FROM Employees
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY YEAR(JoinDate), MONTH(JoinDate)
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY [Year], [Month];
\par 
\par ------------------------------------
\par \hich\af31506\dbch\af31505\loch\f31506 Employees whose names start with 'A' and end with 'T'.
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT *
\par \hich\af31506\dbch\af31505\loch\f31506 FROM Employees
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE Name LIKE 'A%T';
\par --------------------------------------
