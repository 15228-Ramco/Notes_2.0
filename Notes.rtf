\par \hich\af31506\dbch\af31505\loch\f31506     FROM Employees
\par \hich\af31506\dbch\af31505\loch\f31506     WHERE DeptId = e.DeptId
\par \hich\af31506\dbch\af31505\loch\f31506 );
