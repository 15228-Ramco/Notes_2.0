\par --------------------------------------
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 Second highest salary
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 select * from employee
\par \hich\af31506\dbch\af31505\loch\f31506 order by salary desc
\par \hich\af31506\dbch\af31505\loch\f31506 offset 1 row fetch next 1 row only
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 select max(salary) from employee
