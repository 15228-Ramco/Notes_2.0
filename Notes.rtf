\par \hich\af31506\dbch\af31505\loch\f31506 Delete duplictes
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 DELETE FROM Employee
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE EmployeeID NOT IN (
\par \hich\af31506\dbch\af31505\loch\f31506     SELECT MIN(EmployeeID)
\par \hich\af31506\dbch\af31505\loch\f31506     FROM Employee
\par \hich\af31506\dbch\af31505\loch\f31506     GROUP BY EmployeeName, Salary
\par \hich\af31506\dbch\af31505\loch\f31506 );
\par 
