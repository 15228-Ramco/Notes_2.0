\par \hich\af31506\dbch\af31505\loch\f31506 Two sum : Given an array of integers nums and an integer target, return indices of the two numbers such that they add up to target.
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 public int[] TwoSum(int[] nums, int target) \{
\par \hich\af31506\dbch\af31505\loch\f31506         
\par \hich\af31506\dbch\af31505\loch\f31506         Dictionary<int,int> numDict=new Dictionary<int,int>();
\par \hich\af31506\dbch\af31505\loch\f31506         int balance;
\par \hich\af31506\dbch\af31505\loch\f31506         for(int i=0;i<nums.Length;i++)
\par \hich\af31506\dbch\af31505\loch\f31506         \{
\par \hich\af31506\dbch\af31505\loch\f31506             balance=target-nums[i];
\par \hich\af31506\dbch\af31505\loch\f31506             if(numDict.ContainsKey(balance))
\par \hich\af31506\dbch\af31505\loch\f31506             \{
\par \hich\af31506\dbch\af31505\loch\f31506  \hich\af31506\dbch\af31505\loch\f31506                return [numDict[balance],i];
\par \hich\af31506\dbch\af31505\loch\f31506             \}
\par \hich\af31506\dbch\af31505\loch\f31506             else
\par \hich\af31506\dbch\af31505\loch\f31506             \{
\par \hich\af31506\dbch\af31505\loch\f31506                 numDict[nums[i]]=i;
\par \hich\af31506\dbch\af31505\loch\f31506             \}
\par \hich\af31506\dbch\af31505\loch\f31506         \}
\par \hich\af31506\dbch\af31505\loch\f31506         return [];
\par \hich\af31506\dbch\af31505\loch\f31506     \}
\par \}
\par 
