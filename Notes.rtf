\par \tab \hich\af31506\dbch\af31505\loch\f31506 SELECT Email, COUNT(*) AS DuplicateCount
\par \tab \hich\af31506\dbch\af31505\loch\f31506 FROM Employee
\par \tab \hich\af31506\dbch\af31505\loch\f31506 GROUP BY Email
\par \tab \hich\af31506\dbch\af31505\loch\f31506 HAVING COUNT(*) > 1;
\par \tab ----
\par \tab \hich\af31506\dbch\af31505\loch\f31506 SELECT Name, Department, COUNT(*) AS DuplicateCount
\par \tab \hich\af31506\dbch\af31505\loch\f31506 FROM Employee
\par \tab \hich\af31506\dbch\af31505\loch\f31506 GROUP BY Name, Department
\par \tab \hich\af31506\dbch\af31505\loch\f31506 HAVING COUNT(*) > 1;
\par 
