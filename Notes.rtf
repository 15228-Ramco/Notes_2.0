\par \tab 
\par \hich\af31506\dbch\af31505\loch\f31506 3. SQL query tojoin three tables**.
\par \tab \hich\af31506\dbch\af31505\loch\f31506 SELECT e.EmployeeId, e.Name, d.DepartmentName, r.RoleName
\par \tab \hich\af31506\dbch\af31505\loch\f31506 FROM Employee e
\par \tab \hich\af31506\dbch\af31505\loch\f31506 INNER JOIN Department d
\par \tab \tab \hich\af31506\dbch\af31505\loch\f31506 ON e.DepartmentId = d.Departme\hich\af31506\dbch\af31505\loch\f31506 ntId
\par \tab \hich\af31506\dbch\af31505\loch\f31506 INNER JOIN Role r
\par \tab \tab \hich\af31506\dbch\af31505\loch\f31506 ON e.RoleId = r.RoleId;
